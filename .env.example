# Copy this file to `.env.local` and fill in your OpenRouter key.
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-...

# Optional — used for OpenRouter attribution headers
OPENROUTER_APP_URL=http://localhost:3000

# Model routing (per-stage). Override with any model id from https://openrouter.ai/models
# See docs/MODELS.md for the rationale + alternatives. Paste current slugs if these 404.
MODEL_SCORING=anthropic/claude-sonnet-4.6        # validation, refine (calibration-critical)
MODEL_RESEARCH=google/gemini-3-flash-preview     # market (grounded web synthesis)
MODEL_WRITING=google/gemini-2.5-flash            # plan, brand, marketing, pitch, financials, logo
