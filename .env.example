# Copy this file to `.env.local` and fill in your OpenRouter key.
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-...

# Optional — used for OpenRouter attribution headers
OPENROUTER_APP_URL=http://localhost:3000

# Model routing (per-stage). Override with any model id from https://openrouter.ai/models
# Defaults below are sensible picks; paste current slugs if these 404.
MODEL_REASONING=anthropic/claude-opus-4.8
MODEL_RESEARCH=anthropic/claude-sonnet-4.6
MODEL_FAST=google/gemini-2.5-flash
MODEL_IMAGE=google/gemini-2.5-flash-image
