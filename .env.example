# Copy this file to `.env.local` and fill in your OpenRouter key.
# Get a key at https://openrouter.ai/keys

OPENROUTER_API_KEY=sk-or-...

# Optional — used for OpenRouter attribution headers
OPENROUTER_APP_URL=http://localhost:3000

# Accounts (email + password) are always on — the web UI requires sign-in and every idea
# is scoped to its owner. Sessions are httpOnly cookies (secure in production). No config
# needed. Trial credits granted to each self-minted API key (1 per generative call; set 0
# to require top-up before any API use):
#API_TRIAL_CREDITS=5

# Password-reset emails go out via Resend (https://resend.com). Leave RESEND_API_KEY
# unset and reset links are printed to the server console instead — dev mode.
#RESEND_API_KEY=re_...
# Sender address. Defaults to Resend's test sender ("Validorian <onboarding@resend.dev>");
# in production this must be a sender on a domain you've verified with Resend.
#EMAIL_FROM=Validorian <onboarding@resend.dev>

# Model routing (per-role). Override with any model id from https://openrouter.ai/models
# See docs/MODELS.md for the rationale + alternatives. Paste current slugs if these 404.
# Premier config uses THREE distinct families so the audit is a real cross-family check.
MODEL_SCORING=anthropic/claude-opus-4.8          # the judge: validation, refine, deep bull/bear/reconcile
MODEL_WRITING=google/gemini-3-flash-preview      # cheap/fast: evidence queries + ranking, chat, deep CoVe
# Second-family AUDIT judge — scores the same prompt as a cross-family Goodhart check
# (divergence >15/criterion is SURFACED, never averaged into the score). MUST be a
# DIFFERENT family from MODEL_SCORING. GPT-5.1 is the pick: reliable long-JSON, and a
# third family (Anthropic scorer + Google CoVe + OpenAI audit) for maximum independence.
MODEL_AUDIT=openai/gpt-5.1                        # deep mode, every 3rd auto-iterate round, calibrate

# Self-consistency scoring samples per validation (k parallel scoring calls; per-criterion
# median). Opus is a strong single-sample judge, so 2 cuts noise without k=3's cost; use
# 3 with a weaker/cheaper scorer, 1 for single-sample. Deep-validation mode ignores k
# (it runs its own bull + bear + reconcile + CoVe pipeline, ~3-4x a standard call).
SCORING_SAMPLES=2

# ── Evidence sources ─────────────────────────────────────────────────────────────
# Active lineup (routed per idea): Hacker News (always), Stack Overflow, GitHub issues,
# App Store reviews (all keyless), and Web/Exa (keyed — see below). The keys below only
# raise limits or enable the optional/opt-in sources.

# Web search (Exa) — a key from https://dashboard.exa.ai. Enables the "web" source: review
# sites (G2/Capterra/Trustpilot), blogs, competitor & Product Hunt pages, forums, and general
# web discussion — the widest net, and the main demand read for offline/non-technical buyers.
# Without it, the report shows a "Web not connected" hint. (Separate from the grounded scoring
# pass, which uses OpenRouter's built-in Exa plugin and needs no key.)
#EXA_API_KEY=

# GitHub — issue search works unauthenticated (10 req/min); a token raises it to 30/min.
# A classic or fine-grained token with public read scope is plenty.
#GITHUB_TOKEN=

# Stack Exchange — search works without a key; a key raises the shared daily quota.
# Register an app at https://stackapps.com/apps/oauth/register for a key.
#STACKEXCHANGE_KEY=

# YouTube comments (OPT-IN) — off by default; setting this key turns the source on for every
# collection. A browser API key from a Google Cloud project with "YouTube Data API v3" enabled
# (free 10k units/day). Best for consumer/creator/hardware ideas.
#YOUTUBE_API_KEY=

# Reddit (PARKED) — best signal for demand/pain, but self-serve API access is closed and
# commercial use needs Reddit's written approval, so it's NOT in the active lineup. The plugin
# (lib/evidence/reddit.ts) is intact; to re-enable, add "reddit" back to the sources in
# lib/evidence/queries.ts AND set these creds. Left here for when approval lands.
#REDDIT_CLIENT_ID=
#REDDIT_CLIENT_SECRET=

# ── Locale (i18n) ────────────────────────────────────────────────────────────────
# Cookie iv_locale holds the active locale (en/es/fr/de/pt/ja). Default from
# Accept-Language on first visit; switcher in the nav updates it. English catalog
# is complete; other catalogs start empty and fall back to English until filled
# (lib/i18n/messages/). AI output language follows the same cookie.

# ── Billing (campaign pass) ──────────────────────────────────────────────────────
# One Stripe payment unlocks an idea's FULL campaign (validation + wedge tournament +
# kill-test kit + intel + revalidations) up to CAMPAIGN_RUN_CAP scoring runs.
# Only full validations count against the cap; chat/kit/intel do not.
# Leave STRIPE_SECRET_KEY unset and billing is entirely OFF (everything free — local dev).
#STRIPE_SECRET_KEY=sk_test_...
# Production unlock path; local dev works without it (the success redirect is verified
# server-side via /api/billing/confirm). Local webhook testing:
#   stripe listen --forward-to localhost:3000/api/billing/webhook
#STRIPE_WEBHOOK_SECRET=whsec_...
#CAMPAIGN_PRICE_CENTS=2900          # $29 per idea campaign (default)
#CAMPAIGN_RUN_CAP=10                # scoring-run fair-use cap per campaign (COGS guardrail)

# Optional — path to the Chrome/Chromium the PDF export drives (puppeteer-core). Defaults
# to the macOS Google Chrome location; set this if yours is elsewhere or you're not on a Mac.
#CHROME_PATH=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
